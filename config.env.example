# VCP Distributed Server Configuration

# --- Connection to Main Server ---
# The WebSocket URL of the main VCP server.
# Example: ws://127.0.0.1:8088
Main_Server_URL="ws://127.0.0.1:8088"

# The VCP_Key for authenticating with the main server. This must match the main server's key.
VCP_Key="123456"


# --- Server Settings ---
# Enable debug mode for more verbose logging. (True/False)
DebugMode="True"

# A unique name for this distributed server instance.
# This helps in identifying it on the main server's logs.
ServerName="MyDistributedNode-01"

# Defines the primary port for the distributed server's HTTP services (e.g., service plugins).
# Set to 0 to let the system auto-assign an available port.
DIST_SERVER_PORT=7974